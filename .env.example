# Copie este arquivo para .env e preencha suas chaves
# NUNCA faça commit do .env (já está no .gitignore)

# Obtenha em: https://www.themoviedb.org/settings/api
TMDB_API_KEY=sua_chave_tmdb_aqui

# OPCIONAL — para o Chat IA funcionar sem o usuário colocar a própria chave
# Se deixar vazio, o usuário coloca a chave dele na sidebar

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic (Claude) — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Google Gemini — https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Groq (gratuito) — https://console.groq.com/keys
GROQ_API_KEY=
